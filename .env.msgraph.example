# ==============================================================================
# CONFIGURACIÓN DE MICROSOFT GRAPH API PARA ENVÍO DE EMAILS
# ==============================================================================

# ==============================================================================
# PASO 1: Habilitar/Deshabilitar Microsoft Graph
# ==============================================================================
# Cambia a 'true' cuando hayas completado la autenticación con Azure
# Mientras desarrollas, puedes usar 'false' para usar SMTP
MAIL_USE_MICROSOFT_GRAPH=false

# ==============================================================================
# PASO 2: Credenciales de Azure Entra ID (Obtenidas de Azure Portal)
# ==============================================================================

# ID de la Aplicación registrada en Azure Portal
# Ubicación: Azure Portal → Entra ID → Registros de aplicaciones → Tu aplicación → "Application (client) ID"
MSGRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Secreto de cliente creado en Azure Portal
# Ubicación: Azure Portal → Entra ID → Registros de aplicaciones → Tu aplicación → Certificados y secretos
# ⚠️ IMPORTANTE: Solo se muestra una vez, guárdalo en un lugar seguro
MSGRAPH_CLIENT_SECRET=tu_secreto_aqui

# ID del Tenant (Directorio)
# Ubicación: Azure Portal → Entra ID → Registros de aplicaciones → Tu aplicación → "Directory (tenant) ID"
MSGRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000

# ==============================================================================
# PASO 3: Configuración de Usuario
# ==============================================================================

# Email del usuario que enviará los correos (debe estar registrado en tu tenant)
# Ejemplo: notificaciones@tuempresa.onmicrosoft.com
MSGRAPH_USER_EMAIL=notificaciones@tuempresa.onmicrosoft.com

# URI de redirección configurada en Azure (usado en OAuth)
# Debe coincidir exactamente con lo registrado en Azure Portal
# En producción: https://tudominio.com/api/msgraph/auth/callback
# En desarrollo: http://localhost:8000/api/msgraph/auth/callback
MSGRAPH_REDIRECT_URI=http://localhost:8000/api/msgraph/auth/callback

# ==============================================================================
# PASO 4: Configuración de Mail por defecto (SMTP)
# ==============================================================================
# Se usa como fallback si Microsoft Graph no está disponible

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=tu_username@mailgun.org
MAIL_PASSWORD=tu_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@tuempresa.com
MAIL_FROM_NAME="BPay Notificaciones"

# ==============================================================================
# INSTRUCCIONES DE CONFIGURACIÓN
# ==============================================================================
#
# 1. REGISTRAR APLICACIÓN EN AZURE:
#    - Ve a https://portal.azure.com
#    - Busca "Entra ID" o "Azure Active Directory"
#    - Haz clic en "Registros de aplicaciones"
#    - Crea un nuevo registro
#    - Copia: Client ID, Tenant ID, Secreto del cliente
#
# 2. CONFIGURAR PERMISOS:
#    - Ve a "Permisos de API"
#    - Agrega permisos: Mail.Send, offline_access
#    - Aplica consentimiento de administrador
#
# 3. CONFIGURAR REDIRECT URI:
#    - Ve a "Autenticación"
#    - Agrega: http://localhost:8000/api/msgraph/auth/callback
#    - En producción: https://tudominio.com/api/msgraph/auth/callback
#
# 4. COMPLETAR ESTE ARCHIVO:
#    - Copia los valores en las variables de arriba
#
# 5. EJECUTAR AUTENTICACIÓN:
#    - En desarrollo: http://localhost:8000/api/msgraph/auth/redirect
#    - El sistema guardará automáticamente los tokens
#
# 6. PROBAR:
#    - php artisan msgraph:test-email --to=tu@email.com
#
# ==============================================================================
# NOTAS DE SEGURIDAD
# ==============================================================================
#
# ⚠️ NUNCA comitees este archivo .env en git
# ⚠️ NUNCA compartas MSGRAPH_CLIENT_SECRET públicamente
# ⚠️ Usa un .env.local para development
# ⚠️ Usa variables de entorno en producción (no archivos)
# ⚠️ Rota los secretos regularmente
#
# ==============================================================================

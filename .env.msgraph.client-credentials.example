# .env.msgraph.client-credentials.example
# Ejemplo de configuración para Client Credentials Flow
# Copia estos valores a tu .env después de obtenerlos de Azure

# ============================================
# MICROSOFT GRAPH - CLIENT CREDENTIALS
# ============================================

# Habilitar Microsoft Graph para envío de emails
# IMPORTANTE: Cambiar a 'true' solo después de validar en desarrollo
MAIL_USE_MICROSOFT_GRAPH=false

# ============================================
# CREDENCIALES DE AZURE (Client Credentials)
# ============================================

# Obtenidas de Azure Portal → App Registrations → Tu Aplicación

# ID único de la aplicación registrada en Azure
# Dónde obtener: Azure Portal → App Registrations → Overview → Application (client) ID
MSGRAPH_CLIENT_ID=a55226dd-70a8-4fe6-9312-514f70ee18e3

# Secreto de la aplicación (CONFIDENCIAL - NUNCA COMPARTIR)
# Dónde obtener: Azure Portal → App Registrations → Certificates & Secrets → Client secrets
# ⚠️ Se genera una sola vez, después no se puede ver
# ⚠️ NUNCA commitear a git (añadir a .gitignore)
MSGRAPH_CLIENT_SECRET=REEMPLAZAR_CON_CLIENT_SECRET_DE_AZURE

# ID del tenant de Azure (también llamado Directory ID)
# Dónde obtener: Azure Portal → App Registrations → Overview → Directory (tenant) ID
MSGRAPH_TENANT_ID=0337383c-ef94-49c4-b211-4dc358b802ab

# ============================================
# CONFIGURACIÓN DE EMAIL
# ============================================

# Email que aparecerá como remitente por defecto
# Este email DEBE ser una casilla de correo real en tu tenant de Azure
# Con Client Credentials, necesita tener una licencia de Microsoft 365
MSGRAPH_USER_EMAIL=soporte@bpay.com.ar

# Dirección de correo configurada en config/mail.php
# Se usa como fallback si no se proporciona remitente personalizado
MAIL_FROM_ADDRESS=soporte@bpay.com.ar

# ============================================
# NOTAS IMPORTANTES
# ============================================

# 1. DIFERENCIA RESPECTO A OAUTH AUTHORIZATION CODE:
#    ❌ REMOVIDO: MSGRAPH_REDIRECT_URI (no se necesita)
#    ❌ REMOVIDO: Gestión manual de refresh tokens
#    ✅ NUEVO: Obtención automática de tokens

# 2. REQUISITOS EN AZURE:
#    - La app debe tener permiso: Mail.Send
#    - Tipo: Permisos de aplicación (Application, NO delegado)
#    - Estado: Admin consent granted
#    - La casilla de MSGRAPH_USER_EMAIL debe existir y tener licencia

# 3. SEGURIDAD:
#    - Guardar CLIENT_SECRET en ambiente seguro solamente
#    - Nunca commitear al repositorio
#    - Usar variables de entorno en producción
#    - Rotar secreta cada 90 días

# 4. FLUJO DE AUTENTICACIÓN:
#    1. La app envía: CLIENT_ID + CLIENT_SECRET a Azure
#    2. Azure devuelve: access_token
#    3. Token se guarda en caché (expires en 1 hora)
#    4. Token se reutiliza hasta que expire
#    5. Cuando va a expirar, se obtiene uno nuevo automáticamente
#    ⏱️ SIN intervención manual, COMPLETAMENTE automatizado

# 5. TESTING:
#    - Cambiar a true: MAIL_USE_MICROSOFT_GRAPH=true
#    - Ejecutar: php artisan msgraph:test-email --to=usuario@ejemplo.com
#    - Ver logs: tail -f storage/logs/laravel.log

# 6. REMITENTE PERSONALIZADO (Para LEAL MEDICA):
#    Ya se puede hacer dinámicamente en controllers:
#    
#    $this->sendEmail(
#        $emails,
#        $mailable,
#        [],  // attachments
#        'empresa@ejemplo.com',  // fromEmail
#        'Nombre de Empresa'     // fromName
#    );

# ============================================
# DEBUGGING
# ============================================

# Si necesitas resetear el caché de tokens:
# php artisan cache:clear

# Si necesitas ver los logs de autenticación:
# tail -f storage/logs/laravel.log | grep "Microsoft Graph"

# Para obtener información de Azure:
# - Application ID: Azure Portal → App Registrations → Overview
# - Tenant ID: Azure Portal → Azure Active Directory → Properties
# - Client Secret: Azure Portal → App Registrations → Certificates & secrets

# ============================================
# MIGRACIÓN DESDE OAUTH
# ============================================

# Si vienes de OAuth Authorization Code, cambios:
# 1. Remover MSGRAPH_REDIRECT_URI del .env (ya no existe)
# 2. Las rutas /api/msgraph/auth/* fueron deshabilitadas
# 3. Los métodos saveRefreshToken() y getAuthorizationUrl() fueron removidos
# 4. El servicio ahora usa Http::asForm() en lugar de GenericProvider
# 5. TODO es automático sin intervención manual
# 
# Para más detalles ver:
# - MIGRATION_TO_CLIENT_CREDENTIALS.md
# - OAUTH_VS_CLIENT_CREDENTIALS.md

# ============================================
# COMPATIBILIDAD
# ============================================

# ✅ Client Credentials es compatible con:
#    - Laravel 8+
#    - PHP 7.4+
#    - Guzzle 6+
#    - Microsoft Graph API v1.0

# ❌ Lo que NO necesitas más:
#    - OAuth redirect URLs
#    - Gestión manual de refresh tokens
#    - Rutas de callback
#    - Autenticación de usuario
#    - MicrosoftGraphAuthController

